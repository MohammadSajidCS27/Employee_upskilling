APP_ENV=dev
APP_NAME=Learning & Development Platform
GROQ_API_KEY=your_groq_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
GITHUB_TOKEN=your_github_token_here
ONET_API_KEY=your_onet_api_key_here

DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/learning_pathway
CHROMA_PATH=./chroma_db
ESCO_CACHE_PATH=./cache

API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_SECRET=change_me_to_a_random_secret
MAX_UPLOAD_MB=5

LOG_LEVEL=INFO

# Optional dynamic behavior tuning
DEFAULT_ROLE_TITLE=Software Developer
MAX_CORE_GAPS=5
MAX_MARKET_GAPS=5
MAX_EMERGING_SKILLS=10
MAX_TALENT_MATCHES=5
GITHUB_TRENDING_WINDOW_DAYS=365